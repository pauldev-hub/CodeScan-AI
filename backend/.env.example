# Flask Configuration
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_ENV=development
FLASK_APP=run.py
DEBUG=True

# ═══════════════════════════════════════════════════════════════
# MULTI-PROVIDER AI CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Primary AI Provider: Groq
# Sign up at https://console.groq.com/keys
# Free tier: 13,500 requests/day, ultra-fast inference
GROQ_API_KEY=gsk_your_groq_api_key_here

# Fallback AI Provider 1: Google Gemini
# Sign up at https://makersuite.google.com/app/apikey
# Free tier: 1M tokens/month
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback AI Provider 2: Hugging Face Llama
# Sign up at https://huggingface.co/settings/tokens
# Free tier: Inference API available
HUGGING_FACE_API_KEY=hf_your_huggingface_token_here

# Provider order (comma-separated, falls back if previous fails)
# Default: groq,gemini,llama
AI_PROVIDER_ORDER=groq,gemini,llama

# ═══════════════════════════════════════════════════════════════
# GITHUB API
# ═══════════════════════════════════════════════════════════════

# GitHub Personal Access Token for repository fetching
# Create at https://github.com/settings/tokens
# Required scopes: public_repo, read:user
GITHUB_TOKEN=ghp_your_github_token_here

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════

# SQLite (development) - auto-created in backend/instance/
DATABASE_URL=sqlite:///codescan.db

# ═══════════════════════════════════════════════════════════════
# REDIS & CELERY (Async Task Queue)
# ═══════════════════════════════════════════════════════════════

# Redis connection for Celery
# Development: Redis running on localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ═══════════════════════════════════════════════════════════════
# JWT AUTHENTICATION
# ═══════════════════════════════════════════════════════════════

JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# ═══════════════════════════════════════════════════════════════
# CORS & FRONTEND
# ═══════════════════════════════════════════════════════════════

# Frontend URL (whitelisted for CORS)
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════════

RATE_LIMIT_SCANS_PER_HOUR=10

# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════

LOG_LEVEL=DEBUG
