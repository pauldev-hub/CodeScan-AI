# Flask
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me

# Database
# Local development:
DATABASE_URL=sqlite:///codescan.db
# Render production example:
# DATABASE_URL=sqlite:////var/data/codescan.db

# CORS
# Render production example:
# FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
# Optional explicit list (comma separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis / Celery
# For Render, use your internal Redis URL for both values.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Windows local worker note
CELERY_WORKER_POOL=solo

# AI providers
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
HUGGING_FACE_API_KEY=

# GitHub integration
GITHUB_TOKEN=
